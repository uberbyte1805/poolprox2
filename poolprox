#!/bin/bash
# poolprox - PoolProx2 management CLI
# Usage: poolprox [start|stop|restart|status|logs|update|port|build]

# Auto-detect project directory: env override > $POOLPROX_HOME > script's resolved dir
if [ -n "$POOLPROX_HOME" ] && [ -d "$POOLPROX_HOME" ]; then
  PROJECT_DIR="$POOLPROX_HOME"
else
  SCRIPT_PATH="${BASH_SOURCE[0]}"
  while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR=$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)
    SCRIPT_PATH=$(readlink "$SCRIPT_PATH")
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
  done
  PROJECT_DIR=$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)
fi

PID_FILE="$PROJECT_DIR/.poolprox.pid"
LOG_FILE="$PROJECT_DIR/.poolprox.log"
ENV_FILE="$PROJECT_DIR/.env"

is_running() {
  if [ -f "$PID_FILE" ]; then
    local pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    rm -f "$PID_FILE"
  fi
  return 1
}

rotate_log() {
  if [ -f "$LOG_FILE" ]; then
    local size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$size" -gt 5242880 ]; then
      tail -n 1000 "$LOG_FILE" > "$LOG_FILE.tmp"
      mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
  fi
}

do_start() {
  source "$ENV_FILE" 2>/dev/null
  local api_port="${PORT:-1630}"
  local dash_port="${DASHBOARD_PORT:-1631}"

  # Check if ports are already in use
  if ss -tlnp 2>/dev/null | grep -q ":${api_port} "; then
    echo "âťŚ Port $api_port already in use. Run 'poolprox stop' first."
    return 1
  fi
  if ss -tlnp 2>/dev/null | grep -q ":${dash_port} "; then
    echo "âťŚ Port $dash_port already in use. Run 'poolprox stop' first."
    return 1
  fi

  rotate_log
  echo "Starting PoolProx..."
  cd "$PROJECT_DIR"
  nohup bun scripts/production.ts --skip-build >> "$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" > "$PID_FILE"

  # Wait until the backend port is actually accepting connections (max ~30s).
  # This makes the printed URLs truthful: when we print them, the server is ready.
  local ready=0 i=0
  while [ $i -lt 60 ]; do
    if ! kill -0 "$pid" 2>/dev/null; then
      break  # process died early
    fi
    if ss -tlnp 2>/dev/null | grep -q ":${api_port} "; then
      ready=1
      break
    fi
    sleep 0.5
    i=$((i + 1))
  done

  if [ "$ready" = "1" ]; then
    echo "âś… PoolProx started (PID $pid)"
    echo "   Backend:   http://localhost:${api_port}"
    echo "   Dashboard: http://localhost:${dash_port}"
    echo "   Logs:      poolprox logs"
  elif kill -0 "$pid" 2>/dev/null; then
    echo "âš ď¸Ź  PoolProx process is up (PID $pid) but port ${api_port} not ready yet."
    echo "   Still booting â€” check: poolprox logs -f"
    echo "   Backend:   http://localhost:${api_port}"
    echo "   Dashboard: http://localhost:${dash_port}"
  else
    rm -f "$PID_FILE"
    echo "âťŚ Failed to start. Check logs: $LOG_FILE"
    tail -5 "$LOG_FILE"
    return 1
  fi
}

do_stop() {
  echo "Stopping PoolProx..."

  # Kill ALL poolprox-related bun processes regardless of PID file
  pkill -f "bun scripts/production.ts" 2>/dev/null
  pkill -f "bun src/index.ts" 2>/dev/null
  pkill -f "bun run scripts/serve-dashboard.ts" 2>/dev/null

  # Wait for processes to die
  local i=0
  while pgrep -f "bun src/index.ts" >/dev/null 2>&1 && [ $i -lt 10 ]; do
    sleep 0.5
    i=$((i + 1))
  done

  # Force kill if still alive
  if pgrep -f "bun src/index.ts" >/dev/null 2>&1; then
    pkill -9 -f "bun scripts/production.ts" 2>/dev/null
    pkill -9 -f "bun src/index.ts" 2>/dev/null
    pkill -9 -f "bun run scripts/serve-dashboard.ts" 2>/dev/null
    sleep 0.5
  fi

  rm -f "$PID_FILE"
  echo "âŹąď¸Ź  PoolProx stopped"
}

case "$1" in
  start)
    do_start
    ;;
  stop)
    do_stop
    ;;
  restart)
    do_stop
    sleep 1
    do_start
    ;;
  status)
    if is_running; then
      echo "âś… PoolProx is running (PID $(cat "$PID_FILE"))"
      source "$ENV_FILE" 2>/dev/null
      echo "   Backend:   http://localhost:${PORT:-1630}"
      echo "   Dashboard: http://localhost:${DASHBOARD_PORT:-1631}"
    else
      echo "âŹąď¸Ź  PoolProx is not running"
    fi
    ;;
  logs)
    if [ "$2" = "-f" ] || [ -z "$2" ]; then
      tail -f "$LOG_FILE"
    else
      tail -n "${2:-50}" "$LOG_FILE"
    fi
    ;;
  update)
    echo "đź“¦ Pulling latest..."
    cd "$PROJECT_DIR" && git pull
    echo "đź“¦ Installing dependencies..."
    bun install
    echo "đź”¨ Building dashboard..."
    cd "$PROJECT_DIR/dashboard" && bun run build
    echo "đź”„ Restarting..."
    do_stop
    sleep 1
    do_start
    ;;
  build)
    echo "đź”¨ Building dashboard..."
    cd "$PROJECT_DIR/dashboard" && bun run build
    echo "đź”„ Restarting..."
    do_stop
    sleep 1
    do_start
    ;;
  port)
    if [ -z "$2" ] || [ -z "$3" ]; then
      source "$ENV_FILE" 2>/dev/null
      echo "Current ports: API=${PORT:-1630} Dashboard=${DASHBOARD_PORT:-1631}"
      echo "Usage: poolprox port <api_port> <dashboard_port>"
      exit 0
    fi
    sed -i "s/^PORT=.*/PORT=$2/" "$ENV_FILE"
    sed -i "s/^DASHBOARD_PORT=.*/DASHBOARD_PORT=$3/" "$ENV_FILE"
    echo "âś… Ports changed: API=$2 Dashboard=$3"
    if is_running; then
      echo "đź”„ Restarting with new ports..."
      do_stop
      sleep 1
      do_start
    fi
    ;;
  version|--version|-v)
    PKG="$PROJECT_DIR/package.json"
    if [ -f "$PKG" ]; then
      ver=$(grep -m1 '"version"' "$PKG" | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
      echo "poolprox2 v${ver:-unknown}"
    else
      echo "poolprox2 (version unknown)"
    fi
    ;;
  autostart)
    if [ "$2" = "off" ] || [ "$2" = "disable" ]; then
      # Disable systemd --user unit if present
      if command -v systemctl >/dev/null 2>&1 && systemctl --user list-unit-files 2>/dev/null | grep -q '^poolprox2.service'; then
        systemctl --user disable --now poolprox2.service 2>/dev/null
        rm -f "$HOME/.config/systemd/user/poolprox2.service"
        systemctl --user daemon-reload 2>/dev/null
        echo "âŹąď¸Ź  Autostart disabled (systemd --user)"
      fi
      # Remove crontab @reboot fallback
      if crontab -l 2>/dev/null | grep -q "poolprox.*start  # poolprox2-autostart"; then
        crontab -l 2>/dev/null | grep -v "# poolprox2-autostart" | crontab -
        echo "âŹąď¸Ź  Autostart disabled (crontab @reboot)"
      fi
      echo "Autostart removed."
      exit 0
    fi

    # Prefer systemd --user (survives logout if linger enabled), else crontab @reboot
    SELF="$PROJECT_DIR/poolprox"
    if command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1; then
      UDIR="$HOME/.config/systemd/user"
      mkdir -p "$UDIR"
      BUN_BIN="$(command -v bun || echo "$HOME/.bun/bin/bun")"
      BUN_DIR="$(dirname "$BUN_BIN")"
      cat > "$UDIR/poolprox2.service" <<UNIT
[Unit]
Description=PoolProx2 â€” multi-provider AI proxy pool
After=network-online.target

[Service]
Type=simple
WorkingDirectory=$PROJECT_DIR
Environment=PATH=$BUN_DIR:/usr/local/bin:/usr/bin:/bin
ExecStart=$BUN_BIN scripts/production.ts --skip-build
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
UNIT
      systemctl --user daemon-reload
      systemctl --user enable poolprox2.service >/dev/null 2>&1
      # Enable linger so it starts at boot without login (best-effort, needs sudo)
      loginctl enable-linger "$USER" >/dev/null 2>&1 || true
      echo "âś… Autostart enabled (systemd --user)"
      echo "   Starts automatically on login/boot."
      echo "   Disable: poolprox autostart off"
    else
      # Fallback: crontab @reboot
      CRON_LINE="@reboot $SELF start  # poolprox2-autostart"
      ( crontab -l 2>/dev/null | grep -v "# poolprox2-autostart"; echo "$CRON_LINE" ) | crontab -
      echo "âś… Autostart enabled (crontab @reboot)"
      echo "   Disable: poolprox autostart off"
    fi
    ;;
  *)
    echo "poolprox - PoolProx2 Management CLI"
    echo ""
    echo "Usage: poolprox <command>"
    echo ""
    echo "Commands:"
    echo "  start         Start the server (background, prints URLs when ready)"
    echo "  stop          Stop the server"
    echo "  restart       Restart the server"
    echo "  status        Show server status"
    echo "  logs          Follow server logs (poolprox logs -f)"
    echo "  update        Pull git, install deps, build, restart"
    echo "  build         Rebuild dashboard and restart"
    echo "  port          Show/change ports (poolprox port 1630 1631)"
    echo "  autostart     Enable start on boot/login"
    echo "  autostart off Disable autostart"
    echo "  version       Show version"
    ;;
esac
